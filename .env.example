# Redpanda Kafka API (server-side only)
REDPANDA_BROKERS=seed.example.redpanda.cloud:9092
REDPANDA_USERNAME=
REDPANDA_PASSWORD=
REDPANDA_SASL_MECHANISM=scram-sha-256
REDPANDA_TLS=true

# Redpanda Schema Registry (required for SR-framed protobuf values)
SCHEMA_REGISTRY_URL=https://schema-registry.example.redpanda.cloud
SCHEMA_REGISTRY_USERNAME=
SCHEMA_REGISTRY_PASSWORD=

# Optional identity overrides. Keys are MLB gamePk values. A topic value may
# match either the Kafka record key or a source id found in the decoded frame.
# GAME_SOURCE_IDS={"777001":{"espn.game.events.v1":"401...","opticodds.game.events.v1":"..."}}
GAME_SOURCE_IDS={}

# Set to true to exercise the full UI without Redpanda credentials.
DEMO_MODE=false
